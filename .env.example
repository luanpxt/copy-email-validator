# Senha de acesso da ferramenta (compartilhada com o time)
APP_PASSWORD=00000

# Chave secreta para sessões Flask (gere uma aleatória)
SECRET_KEY=troque-por-uma-chave-aleatoria-longa

# (Opcional) Chave da API Anthropic para sugestões em linguagem natural
# Sem ela, a ferramenta usa sugestões baseadas em regras
ANTHROPIC_API_KEY=
